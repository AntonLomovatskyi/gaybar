{
  "name": "gaybar",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "prettier --check . && eslint . && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "export:web": "expo export --platform web",
    "deploy:web": "expo export --platform web && eas deploy",
    "prepare": "husky",
    "validate": "tsx scripts/validate.ts",
    "gen:index": "tsx scripts/gen-index.ts",
    "gen:app-data": "tsx scripts/gen-app-data.ts",
    "gen:catalog": "tsx scripts/gen-catalog.ts",
    "gen:card-image": "tsx scripts/gen-card-image.ts",
    "gen:icons": "tsx scripts/gen-app-icons.ts"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@shopify/flash-list": "1.7.6",
    "@types/react": "~19.0.14",
    "@types/react-dom": "^19.2.3",
    "eslint-config-expo": "~9.2.0",
    "expo": "^53.0.0",
    "expo-constants": "~17.1.8",
    "expo-crypto": "~14.1.5",
    "expo-document-picker": "~13.1.6",
    "expo-file-system": "~18.1.11",
    "expo-haptics": "~14.1.4",
    "expo-image": "~2.4.1",
    "expo-keep-awake": "~14.1.4",
    "expo-linking": "~7.1.7",
    "expo-localization": "~16.1.6",
    "expo-router": "~5.1.11",
    "expo-sharing": "~13.1.5",
    "expo-splash-screen": "~0.30.10",
    "expo-status-bar": "~2.2.3",
    "i18next": "^26.3.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-i18next": "^17.0.8",
    "react-native": "0.79.6",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-web": "^0.20.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "sharp": "^0.35.1",
    "tsx": "^4.22.4",
    "typescript": "~5.8.3",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,md}": "prettier --write",
    "{app,src}/**/*.{ts,tsx}": "eslint --fix"
  }
}
