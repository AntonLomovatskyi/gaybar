{
  "expo": {
    "name": "gaybar",
    "slug": "gaybar",
    "scheme": "gaybar",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "backgroundColor": "#0E0E10",
    "primaryColor": "#D9B25A",
    "newArchEnabled": true,
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gaybar.app"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.gaybar.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0E0E10"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png",
      "name": "gaybar",
      "shortName": "gaybar",
      "themeColor": "#0E0E10",
      "backgroundColor": "#0E0E10",
      "display": "standalone",
      "lang": "uk"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0E0E10"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/gaybar"
    }
  }
}
